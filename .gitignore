# Local .terraform directories
**/.terraform/*
**/.terraform.lock.hcl

# .tfstate files and backups
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which might contain sensitive data
# RENAME terraform.tfvars.example to terraform.tfvars and commit the example file
*.tfvars
*.tfvars.json

# Ignore override files, which are usually used for local testing
# and not intended for version control
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Optional: ignore plan files saved before applying
# example: *tfplan*
